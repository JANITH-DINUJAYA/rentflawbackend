# RentFlaw Backend — Environment Variables
# Copy this file to .env and fill in all values before running the server.
# NEVER commit .env to version control.

# ─── App ─────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database (Neon PostgreSQL) ──────────────────
# Pooled connection (use for Prisma Client queries)
DATABASE_URL="postgresql://neondb_owner:npg_lhi1cYrSgGD4@ep-aged-smoke-aztzihpi-pooler.c-3.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct connection (use for Prisma migrations only)
DIRECT_URL="postgresql://neondb_owner:npg_lhi1cYrSgGD4@ep-aged-smoke-aztzihpi.c-3.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── JWT ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-super-secure-access-secret-min-64-hex-chars
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-min-64-hex-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis (Railway Redis add-on or Upstash) ─────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Cloudinary (File / Receipt Storage) ─────────
# Found in: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=dghvmufcn
CLOUDINARY_API_KEY=518219927332536
CLOUDINARY_API_SECRET=v5gTY3azZQgIm-iJJpsEmdm5Lsw

# ─── Email (Resend) ───────────────────────────────
RESEND_API_KEY=re_FppNAkPA_9aYbwznGqcY9rL7vuATE8gtx
EMAIL_FROM=noreply@rentflaw.com

# ─── Frontend ─────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
